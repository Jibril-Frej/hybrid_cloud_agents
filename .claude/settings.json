{
  "env": {
    "MAX_THINKING_TOKENS": "10000"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(manifests/**)",
      "Write(docker/**)",
      "Write(docs/**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git merge *)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(uv run mkdocs:*)",
      "Bash(docker:*)",
      "Bash(kind:*)",
      "Bash(k3d:*)",
      "Bash(kubectl:*)",
      "Bash(uv run python:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run pytest tests/unit/ tests/integration/boundary/ -q)",
      "Read(//home/user/.ssh/**)",
      "Bash(ssh-add -l)",
      "Bash(git rm *)",
      "Bash(uv --version)",
      "Bash(uv lock *)",
      "Bash(uv sync*)",
      "Bash(uv venv*)",
      "Bash(make test *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-commit-msg.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-commit-docs.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/run-tests-gate.sh"
          }
        ]
      }
    ]
  }
}

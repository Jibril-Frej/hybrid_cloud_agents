{
  "env": {
    "MAX_THINKING_TOKENS": "10000"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(manifests/**)",
      "Write(docker/**)",
      "Write(docs/**)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mkdocs:*)",
      "Bash(docker:*)",
      "Bash(kind:*)",
      "Bash(k3d:*)",
      "Bash(kubectl:*)",
      "Bash(PYTHONPATH=src pylint src/ --disable=all --enable=C0114,C0115,C0116,C0103,W0603,W0718)",
      "Bash(PYTHONPATH=src pylint src/ tests/ --disable=all --enable=C0114,C0115,C0116,C0103,W0603,W0718)",
      "Bash(PYTHONPATH=src pylint tests/ --disable=all --enable=C0114,C0115,C0116)",
      "Bash(PYTHONPATH=src python -m pytest tests/unit/ tests/integration/boundary/ -q)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./**/.env)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Bash(git push --force:*)",
      "Bash(rm -rf:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-commit-msg.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/run-tests-gate.sh"
          }
        ]
      }
    ]
  }
}
